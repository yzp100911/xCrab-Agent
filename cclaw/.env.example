# claw-client 配置
# 重命名此文件为 .env 后即可生效

# eclaw-server HTTP API 地址（必须）
# 如果 eclaw-server 在同一台机器：http://127.0.0.1:10090
# 如果 eclaw-server 在远程服务器：http://你的服务器IP:10090
ECLAW_API_URL=http://127.0.0.1:10090

# eclaw-server WebSocket 地址（必须）
# 通常与 API 地址同机，只需 ws://主机:端口/ws
ECLAW_WS_URL=ws://127.0.0.1:10090/ws

# AI 后端选择（可选，默认 xcrab）
# xcrab = 使用 xCrab-Agent（推荐）
# hermes = 旧版后端（已废弃）
CCLAW_AI_BACKEND=xcrab

# xCrab-Agent 网关地址（可选）
# 当 CCLAW_AI_BACKEND=xcrab 时，连接到这里调用 AI
XCRAB_GATEWAY_URL=http://localhost:3000

# xCrab-Agent 网关令牌（可选）
# 与 xCrab-Agent 配置的 TOKEN 保持一致
XCRAB_GATEWAY_TOKEN=你的令牌
