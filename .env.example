# MiniMax API 配置
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# DeepSeek API 配置（切换模型时自动使用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型配置
MODEL=MiniMax-M2.7

# 持久化记忆（true/false）
ENABLE_MEMORY=false

# 记忆数据库路径（默认 ./memory/memories.db）
# MEMORY_DB_PATH=./memory/memories.db

# 自动保存对话摘要（true/false）
MEMORY_AUTO_SUMMARY=true

# Gateway HTTP 服务（true/false）
# GATEWAY_ENABLED=false

# Gateway 服务端口（默认 3000）
# GATEWAY_PORT=3000

# Gateway JWT 密钥
# GATEWAY_JWT_SECRET=xcatch-gateway-secret

# Gateway 静态令牌（前端连接用，为空则生成随机）
# GATEWAY_TOKEN=

# MCP 服务器配置（JSON 格式）
# MCP_SERVERS=[{"id":"example","command":"node","args":["server.js"]}]

# 自定义 Hook 目录
# HOOKS_DIR=./hooks

# 工作区根目录（默认 data/）
# WORKSPACE_DIR=./data

# 默认激活的工作区（默认 main）
# ACTIVE_WORKSPACE=main
