# ══════════════════════════════════════════════
# 🧠 skillgate-agent — AI 对话引擎 配置
# ══════════════════════════════════════════════

# MiniMax API 配置（必填）
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# DeepSeek API 配置（切换模型时自动使用）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 模型配置
MODEL=MiniMax-M2.7

# 持久化记忆（true/false）
ENABLE_MEMORY=false

# 自动保存对话摘要（true/false）
MEMORY_AUTO_SUMMARY=true

# Gateway HTTP 服务（true/false）
# GATEWAY_ENABLED=false

# Gateway 服务端口（默认 3000）
# GATEWAY_PORT=3000

# Gateway JWT 密钥
# GATEWAY_JWT_SECRET=xcatch-gateway-secret

# Gateway 静态令牌（前端/Gateway 连接用，为空则生成随机）
# GATEWAY_TOKEN=

# MCP 服务器配置（JSON 格式）
# MCP_SERVERS=[{"id":"example","command":"node","args":["server.js"]}]

# 工作区根目录（默认 data/）
# WORKSPACE_DIR=./data

# 默认激活的工作区（默认 main）
# ACTIVE_WORKSPACE=main


# ══════════════════════════════════════════════
# 📡 eclaw-server — 中转调度服务器 配置
# ══════════════════════════════════════════════

# eclaw-server 端口（默认 10090）
# ECLAW_PORT=10090

# skillgate-agent 网关地址（用于转发 AI 回复）
# XCRAB_API_URL=http://localhost:3000

# 鉴权令牌（前端/客户端连接验证用）
# XCRAB_TOKEN=your_token_here


# ══════════════════════════════════════════════
# 🤖 claw-client — 远程执行终端 配置
# ══════════════════════════════════════════════

# eclaw-server HTTP API 地址（必须）
# 同机：http://127.0.0.1:10090   远程：http://服务器IP:10090
# ECLAW_API_URL=http://127.0.0.1:10090

# eclaw-server WebSocket 地址（必须）
# ECLAW_WS_URL=ws://127.0.0.1:10090/ws

# AI 后端选择（xcrab / hermes，默认 xcrab）
# CCLAW_AI_BACKEND=xcrab

# skillgate-agent 网关令牌（与 GATEWAY_TOKEN 保持一致）
# XCRAB_GATEWAY_TOKEN=
